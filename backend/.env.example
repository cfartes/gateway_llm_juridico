OPS_ALERT_COOLDOWN_SECONDS=900
QUEUE_ETA_WORKER_SLOTS_LIGHT=1
QUEUE_ETA_WORKER_SLOTS_STANDARD=1
QUEUE_ETA_WORKER_SLOTS_HEAVY=1
