WEBHOOK_CALLBACK_ALLOWED_DOMAINS=
WEBHOOK_CALLBACK_ALLOW_HTTP_LOCALHOST=true
WEBHOOK_CALLBACK_BLOCK_PRIVATE_NETWORKS=true
WEBHOOK_DEAD_LETTER_AUTO_RETRY_ENABLED=true
WEBHOOK_DEAD_LETTER_AUTO_RETRY_INTERVAL_SECONDS=120
WEBHOOK_DEAD_LETTER_AUTO_RETRY_BATCH_SIZE=25
WEBHOOK_DEAD_LETTER_AUTO_RETRY_MAX_TOTAL_ATTEMPTS=12
WEBHOOK_DEAD_LETTER_AUTO_RETRY_MIN_AGE_SECONDS=60
WEBHOOK_DEAD_LETTER_AUTO_RETRY_MAX_DELAY_SECONDS=1800
OPS_ALERT_WEBHOOK_URL=
