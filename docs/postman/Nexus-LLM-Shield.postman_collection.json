  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_name\": \"{{tenantName}}\",\n  \"tenant_slug\": \"{{tenantSlug}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"full_name\": \"{{adminFullName}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  var json = pm.response.json();",
                  "  if (json.access_token) pm.environment.set('accessToken', json.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
