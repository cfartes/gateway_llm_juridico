    {
      "name": "API Tokens",
      "item": [
        {
          "name": "Create API Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"External Integration\",\n  \"scopes\": [\"scan:write\", \"scan:read\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/tokens",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tokens"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  var json = pm.response.json();",
                  "  if (json.token) pm.environment.set('apiToken', json.token);",
                  "}"
